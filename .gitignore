# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Secrets / local config
config.yaml
.env
*.key

# Data pulls — large, regenerable from the APIs; keep out of git.
data/*.csv
data/*.parquet
data/*.feather
# logged + backfilled option-chain OI snapshots (runtime-only)
data/oi/
# persistent local OHLCV store (pull-once, accumulate-for-years)
data/ohlcv/
# pasted chart exports for trigger validation (throwaway)
data/validate/

# Results — keep human-readable reports, drop raw dumps + runtime logs/DB.
results/*.csv
results/*.parquet
results/*.jsonl
results/*.db
!results/*.md
