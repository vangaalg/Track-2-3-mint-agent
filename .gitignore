# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Secrets / local config
config.yaml
.env
*.key

# Data pulls — large, regenerable from the APIs; keep out of git.
data/*.csv
data/*.parquet
data/*.feather
data/oi/                 # logged + backfilled option-chain OI snapshots

# Results — keep human-readable reports, drop raw dumps + runtime logs/DB.
results/*.csv
results/*.parquet
results/*.jsonl
results/*.db
!results/*.md
