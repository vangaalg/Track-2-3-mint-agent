# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Secrets / local config
config.yaml
.env
*.key

# Data pulls — large, regenerable from the APIs; keep out of git.
data/*.csv
data/*.parquet
data/*.feather
# logged + backfilled option-chain OI snapshots (runtime-only)
data/oi/
# per-instrument OI summary time series (PCR/max-pain/levels — plot data)
data/oi_summary/
# macro time series (VIX / USD-INR / indices / crude)
data/macro/
# trader's daily overlay (manual GIFT + overnight-events note)
data/*.json
# persistent local OHLCV store (pull-once, accumulate-for-years)
data/ohlcv/
# pasted chart exports for trigger validation (throwaway)
data/validate/
# recorder's persisted daily Breeze token (restored from the private data repo, not here)
data/recorder_state/
# cockpit service's git-backed journal store (cloned from JOURNAL_REPO_URL at runtime)
journal_store/

# Results — keep human-readable reports, drop raw dumps + runtime logs/DB.
results/*.csv
results/*.parquet
results/*.jsonl
results/*.db
!results/*.md
